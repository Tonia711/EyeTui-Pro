# ============================================
# PostgreSQL Database Configuration
# ============================================
# Copy this file to .env and fill in your actual configuration:
#   copy env.example .env  (Windows)
#   cp env.example .env    (Linux/Mac)
#
# Format: postgresql://username:password@host:port/database_name
# ============================================

# For local trusted connection (no password required)
DATABASE_URL=postgresql://postgres@localhost:5432/hospital_lens

# For connection with password (uncomment and modify if needed)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/hospital_lens

# ============================================
# Other Optional Configuration (Future Extensions)
# ============================================
# DEBUG=true
# SECRET_KEY=your-secret-key-here


